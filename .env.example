# Interview Prep Portal - Environment Variables
# Copy this file to .env and adjust values for your setup.

# Port for the development server
VITE_PORT=5173

# Base path for GitHub Pages deployment
VITE_BASE_PATH=/interview-prep-portal/

# Plugin server port (Hermes Agent plugin)
PREP_PORTAL_PORT=8766

# Optional: Path to your local interview-prep-portal clone
PREP_PORTAL_DIR=/home/YOUR_USERNAME/interview-prep-portal
